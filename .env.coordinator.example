# .env.coordinator — Variáveis de ambiente do Coordenador da Mitra Factory
#
# Este arquivo vive em /opt/mitra-factory/.env.coordinator (NÃO é o .env da
# raiz do repo — aquele é do webhook do Telegram).
#
# Por que .env.coordinator e não .env puro: por isolamento.
# Se um sub-agente (Dev/QA) rodar scripts com `import 'dotenv/config'` na
# pasta errada, o Node tenta carregar o .env mais próximo no filesystem.
# Se o Coordenador usasse .env puro em /opt/mitra-factory/, o Dev podia
# pegar essas variáveis acidentalmente e contaminar o banco da fábrica
# (incidente real já ocorreu). Usar .env.coordinator força o Coordenador
# a carregar explicitamente com dotenv.config({ path: '/opt/mitra-factory/.env.coordinator' })
# e sub-agentes nunca pegam por acidente.
#
# Ver coordinator.md seção 8.11 "Isolar o .env do Coordenador".

# === Plataforma Mitra ===
MITRA_BASE_URL=https://newmitra.mitrasheet.com:8080
MITRA_BASE_URL_INTEGRATIONS=https://newmitra.mitrasheet.com:8080

# === Fábrica (cérebro — FACTORY_PROJECT) ===
FACTORY_PROJECT_ID=        # ID do projeto Mitra que serve de cérebro da fábrica
FACTORY_WORKSPACE_ID=      # ID do workspace onde o projeto cérebro vive
FACTORY_TOKEN=             # Token do workspace do cérebro (leitura/escrita nas tabelas PIPELINE, HISTORICO_QA, etc.)

# === Workspace de desenvolvimento (DEV_WORKSPACE) ===
# Separado do cérebro — é aqui que o Dev cria os projetos dos sistemas verticais
DEV_WORKSPACE_ID=
DEV_WORKSPACE_TOKEN=

# === Opcional ===
GEMINI_API_KEY=            # Se os sistemas vão usar Gemini como IA opcional (com fallback determinístico)
